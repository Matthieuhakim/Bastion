{
  "name": "bastion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/api",
    "packages/sdk-node"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'",
    "db:migrate": "npm run db:migrate --workspace=packages/api",
    "db:studio": "npm run db:studio --workspace=packages/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
