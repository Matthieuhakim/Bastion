{
  "name": "bastion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/api",
    "packages/sdk-node",
    "packages/dashboard",
    "packages/openclaw-plugin"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/api",
    "build": "npm run build --workspaces --if-present",
    "dev:dashboard": "npm run dev --workspace=packages/dashboard",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'",
    "db:migrate": "npm run db:migrate --workspace=packages/api",
    "db:studio": "npm run db:studio --workspace=packages/api",
    "test": "npm run test --workspace=packages/api && npm run test --workspace=packages/sdk-node && npm run test --workspace=packages/openclaw-plugin",
    "test:e2e": "npm run test:e2e --workspace=packages/dashboard",
    "test:integration": "npm run test:integration --workspace=packages/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
