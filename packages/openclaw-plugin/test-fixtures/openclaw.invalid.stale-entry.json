{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "__OPENCLAW_GATEWAY_TOKEN__"
    }
  },
  "plugins": {
    "allow": ["bastion-fetch"],
    "entries": {
      "bastion-fetch": {
        "enabled": true,
        "config": {
          "serverUrl": "__BASTION_SERVER_URL__",
          "agentSecret": {
            "$env": "BASTION_AGENT_SECRET"
          },
          "rules": [
            {
              "tool": "web_fetch",
              "urlPattern": "__URL_PATTERN__",
              "credentialId": "__CREDENTIAL_ID__",
              "action": "__ACTION__"
            }
          ]
        }
      }
    }
  }
}
