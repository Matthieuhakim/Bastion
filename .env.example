# Copy to /packages/api/.env

# Database
DATABASE_URL=postgresql://bastion:bastion@localhost:5432/bastion
REDIS_URL=redis://localhost:6379
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
# Comma-separated list. In production, set this to your dashboard/API origins.
CORS_ORIGINS=

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
MASTER_KEY=

# Admin API key for managing agents/credentials/policies
PROJECT_API_KEY=

# Optional LLM intent judge. Enable per policy with constraints.intentReview.enabled=true.
INTENT_JUDGE_ENABLED=false
INTENT_JUDGE_PROVIDER=openai
INTENT_JUDGE_MODEL=gpt-4o-mini
INTENT_JUDGE_API_KEY=
INTENT_JUDGE_ENDPOINT=https://api.openai.com/v1/chat/completions
INTENT_JUDGE_TIMEOUT_MS=10000
